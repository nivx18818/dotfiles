// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // Appearance
  "ui_font_family": "DankMono Nerd Font",
  "buffer_font_family": "DankMono Nerd Font",
  "buffer_font_features": {
    "calt": true,
  },
  "ui_font_size": 18,
  "agent_buffer_font_size": 18,
  "buffer_font_size": 18,
  "buffer_line_height": {
    "custom": 2,
  },
  "icon_theme": "Light Charmed Icons",
  "theme": "Vesper",
  "theme_overrides": {
    "Vesper": {
      "terminal.foreground": "#ffffff",
      "terminal.ansi.white": "#ffffff",
      "terminal.ansi.green": "#99FFE4",
      "terminal.ansi.yellow": "#FFC799",
      "syntax": {
        "comment": {
          "font_style": "italic",
        },
        "comment.doc": {
          "font_style": "italic",
        },
      },
    },
  },
  "title_bar": {
    "show_branch_status_icon": false,
    "show_branch_name": false,
    "show_project_items": false,
    "show_user_picture": false,
    "show_user_menu": false,
  },
  "tab_bar": {
    "show": false,
  },
  "toolbar": {
    "quick_actions": false,
  },
  "status_bar": {
    "experimental.show": false,
  },
  "project_panel": {
    "default_width": 300,
    "hide_root": true,
    "auto_fold_dirs": false,
    "starts_open": false,
    "sticky_scroll": false,
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "never",
    },
  },
  "git_panel": {
    "tree_view": true,
  },
  "terminal": {
    "default_height": 500,
    "scrollbar": {
      "show": "never",
    },
    "shell": {
      "with_arguments": {
        "program": "pwsh",
        "args": ["-NoLogo"],
      },
    },
  },
  "file_finder": {
    "modal_max_width": "small",
  },
  "scrollbar": {
    "show": "never",
  },
  "current_line_highlight": "none",
  "tab_size": 2,
  "hard_tabs": false,
  "centered_layout": {
    "right_padding": 0.15,
    "left_padding": 0.15,
  },
  "inline_code_actions": false,
  "gutter": {
    "bookmarks": false,
    "breakpoints": false,
    "folds": false,
    "runnables": false,
    "min_line_number_digits": 0,
  },
  "hide_mouse": "on_typing_and_action",

  // Behaviors
  "auto_update": false,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "format_on_save": "on",
  "cli_default_open_behavior": "new_window",
  "close_on_file_delete": true,
  "when_closing_with_no_tabs": "keep_window_open",
  "restore_on_file_reopen": false,
  "restore_on_startup": "last_workspace",
  "session": {
    "restore_unsaved_buffers": false,
  },
  "show_edit_predictions": false,
  "edit_predictions": {
    "provider": "copilot",
  },
  "context_servers": {
    "figma-mcp-go": {
      "enabled": false,
      "remote": false,
      "command": "npx",
      "args": ["@vkhanhqui/figma-mcp-go@latest"],
      "env": {},
    },
  },
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "extend_comment_on_newline": false,
  "horizontal_scroll_margin": 1,
  "vertical_scroll_margin": 10,
  "multi_cursor_modifier": "cmd_or_ctrl",
  "relative_line_numbers": "enabled",
  "soft_wrap": "editor_width",
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  // Vim
  "vim_mode": true,
  "which_key": {
    "enabled": true,
    "delay_ms": 0,
  },
  "vim": {
    "highlight_on_yank_duration": 200,
    "use_regex_search": true,
    "use_smartcase_find": true,
    "use_system_clipboard": "always",
  },

  // Languages
  "languages": {
    "TSX": {
      "formatter": [{ "code_action": "source.fixAll.eslint" }, "prettier"],
    },
    "JavaScript": {
      "formatter": [{ "code_action": "source.fixAll.eslint" }, "prettier"],
    },
    "CSS": {
      "formatter": [{ "code_action": "source.fixAll.stylelint" }, "prettier"],
    },
    "HTML": {
      "formatter": "prettier",
    },
    "C++": {
      "tab_size": 4,
    },
  },
}

