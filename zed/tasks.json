// Project tasks configuration. See https://zed.dev/docs/tasks for documentation.
[
  {
    "label": "CodeSnap",
    "command": "codesnap",
    "args": [
      "-o=clipboard",
      "--file-path=$ZED_RELATIVE_FILE",
      "--has-line-number",
      "--start-line-number=$ZED_ROW",
      "--disable-watermark",
      "-c=\"$ZED_SELECTED_TEXT\"",
    ],
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "on_success",
    "shell": "system",
  },
  {
    "label": "Lazygit",
    "command": "lazygit",
    "reveal_target": "center",
  },
]
