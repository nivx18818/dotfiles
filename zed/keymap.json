// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "vim_mode == normal || vim_mode == visual || EmptyPane || SharedScreen",
    "bindings": {
      "g s": "vim::PushAddSurrounds",

      "space": null,
      "space space": "file_finder::Toggle",
      "space e": "project_panel::ToggleFocus",
      "space t": "terminal_panel::ToggleFocus",

      // +git
      "space g g": "git_panel::ToggleFocus",
      "space g h": "git::FileHistory",
      "space g b": "git::Blame",
      "space g l": ["task::Spawn", { "task_name": "Lazygit" }],

      // +quit
      "space q q": "workspace::CloseWindow",
      "space q a": "zed::Quit",
    },
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "ctrl-\\": "copilot::Suggest",
      "ctrl-i": "assistant::InlineAssist",
      "ctrl-v": "editor::Paste",
    },
  },
  {
    "context": "!menu && (vim_mode == normal || vim_mode == visual)",
    "bindings": {
      "j": ["vim::Down", { "display_lines": true }],
      "k": ["vim::Up", { "display_lines": true }],

      "s": "vim::HelixJumpToWord",

      "b": "vim::PreviousSubwordStart",
      "e": "vim::NextSubwordEnd",
      "g e": "vim::PreviousSubwordEnd",

      "g p": ["workspace::SendKeystrokes", "\" 0 p"],
      "g P": ["workspace::SendKeystrokes", "\" 0 P"],
    },
  },
  {
    "context": "!menu && VimCount && (vim_mode == normal || vim_mode == visual)",
    "bindings": {
      "j": "vim::Down",
      "k": "vim::Up",
    },
  },
  {
    "context": "!menu && vim_mode == normal",
    "bindings": {
      "Y": ["workspace::SendKeystrokes", "y g _"],

      // Temporary alternative for https://github.com/zed-industries/zed/discussions/57799
      "space v g": "editor::SelectAll",
      "space y g": ["workspace::SendKeystrokes", ": % y enter"],
      "space c g": ["workspace::SendKeystrokes", "g g c G"],
      "space d g": ["workspace::SendKeystrokes", "g g d G"],

      "space v l": ["workspace::SendKeystrokes", "_ v g _"],
      "space y l": ["workspace::SendKeystrokes", "_ y g _"],
      "space c l": ["workspace::SendKeystrokes", "_ c g _"],
      "space d l": ["workspace::SendKeystrokes", "_ d g _"],
    },
  },
  {
    "context": "!menu && vim_mode == visual",
    "bindings": {
      "shift-j": "editor::MoveLineDown",
      "shift-k": "editor::MoveLineUp",

      ">": ["workspace::SendKeystrokes", "> g v"],
      "<": ["workspace::SendKeystrokes", "< g v"],
    },
  },
  {
    "context": "!menu && vim_mode == operator && vim_operator == gc",
    "bindings": {
      "o": [
        "action::Sequence",
        ["vim::InsertLineBelow", "vim::ToggleComments"],
      ],
      "O": [
        "action::Sequence",
        ["vim::InsertLineAbove", "vim::ToggleComments"],
      ],
    },
  },
  {
    "context": "ProjectPanel && !editing",
    "bindings": {
      "a": "project_panel::NewFile",
      "A": "project_panel::NewDirectory",
      "d": "project_panel::Delete",
      "y": "project_panel::Copy",
      "Y": "workspace::CopyPath",
      "p": "project_panel::Paste",
      "x": "project_panel::Cut",
      "r": "project_panel::Rename",
      "R": "project_panel::RevealInFileManager",
      "z": "project_panel::CollapseAllEntries",
    },
  },
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual)",
    "bindings": {
      "m": "vim::PushMark",
      "g m": ["workspace::SendKeystrokes", "`"],
      "g M": ["workspace::SendKeystrokes", "'"],
      "space d m": ["workspace::SendKeystrokes", ": d e l m space"],

      // +file/find
      "space f f": "file_finder::Toggle",
      "space f b": "tab_switcher::ToggleAll",
      "space f n": "workspace::NewFile",
      // +indentation
      "space f i t": "editor::ConvertIndentationToTabs",
      "space f i s": "editor::ConvertIndentationToSpaces",

      // +search
      "space s s": "project_symbols::Toggle",
      "space s o": "outline::Toggle",
      "space s g": "pane::DeploySearch",

      // +tabs
      "space tab d": "pane::CloseAllItems",
      "space tab D": "workspace::CloseAllItemsAndPanes",

      // +windows
      "space w n": "workspace::NewWindow",
      "space w r": "workspace::Reload",
      "space w h": "pane::SplitDown",
      "space w v": "pane::SplitRight",

      // +buffers
      "space b b": [
        "action::Sequence",
        ["tab_switcher::Toggle", ["workspace::SendKeystrokes", "enter"]],
      ],
      "space b d": "pane::CloseActiveItem",
      "space b o": "pane::CloseOtherItems",
      "space b u": "pane::ReopenClosedItem",
      "space b h": "pane::SplitAndMoveLeft",
      "space b j": "pane::SplitAndMoveDown",
      "space b k": "pane::SplitAndMoveUp",
      "space b l": "pane::SplitAndMoveRight",
      "space b y": "workspace::CopyRelativePath",

      // +code/chat/command
      "space c p": "command_palette::Toggle",
      "space c c": "agent::FocusAgent",
      "space c i": "assistant::InlineAssist",
      "space c a": "editor::ToggleCodeActions",
      "space c o": "editor::OrganizeImports",
      "space c f": "editor::Format",
      "space c s": ["task::Spawn", { "task_name": "CodeSnap" }],

      // +diagnostics
      "space d d": "diagnostics::Deploy",
      "space d n": "editor::GoToDiagnostic",
      "space d N": "editor::GoToPreviousDiagnostic",

      // +git
      "space g d": "editor::ToggleSelectedDiffHunks",
      "space g u": "git::Restore",

      // +text
      "space x s": "editor::SortLinesCaseInsensitive",
      // +transform
      "space x t c": "editor::ConvertToLowerCamelCase",
      "space x t k": "editor::ConvertToKebabCase",
      "space x t P": "editor::ConvertToUpperCamelCase",
      "space x t s": "editor::ConvertToSnakeCase",
      "space x t S": [
        "action::Sequence",
        ["editor::ConvertToSnakeCase", "editor::ConvertToUpperCase"],
      ],
      "space x t T": "editor::ConvertToTitleCase",

      // +ui
      "space u m": "markdown::OpenPreview",
      "space u M": "markdown::OpenPreviewToTheSide",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "ctrl-i": "assistant::InlineAssist",
    },
  },
  {
    "context": "!Terminal && ((menu && !showing_completions) || EmptyPane || SharedScreen || vim_mode == normal || vim_mode == visual)",
    "bindings": {
      // +ui
      "space u h": "workspace::ToggleLeftDock",
      "space u H": "multi_workspace::ToggleWorkspaceSidebar",
      "space u j": "workspace::ToggleBottomDock",
      "space u l": "workspace::ToggleRightDock",
      "space u d": "workspace::CloseAllDocks",
      "space u z": "workspace::ToggleCenteredLayout",
      "space u t": "theme_selector::Toggle",
      "space u i": "icon_theme_selector::Toggle",
      "space u x": "zed::Extensions",
      "space u ,": "zed::OpenSettingsFile",
      "space u .": "zed::OpenKeymapFile",
      "space u /": "zed::OpenTasks",
      "space u L": "editor::ToggleRelativeLineNumbers",
    },
  },
  {
    "context": "!Terminal && (Pane || Dock) && vim_mode != insert",
    "bindings": {
      "ctrl-w": null,
      "ctrl-w d": "pane::CloseActiveItem",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-t": null,
      "ctrl-t n": "workspace::NewTerminal",
      "ctrl-t d": "pane::CloseActiveItem",
      "ctrl-t h": "pane::ActivatePreviousItem",
      "ctrl-t l": "pane::ActivateNextItem",
      "ctrl-w h": "workspace::ActivatePaneLeft",
      "ctrl-w k": "workspace::ActivatePaneUp",
      "ctrl-w j": "workspace::ActivatePaneDown",
      "ctrl-w l": "workspace::ActivatePaneRight",
    },
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "ctrl-t": null,
      "ctrl-n": null,
      "ctrl-p": null,
      "ctrl-g n": "agent::ToggleNewThreadMenu",
      "ctrl-g m": "agent::ToggleModelSelector",
      "ctrl-g t": "agent::ToggleThinkingEffortMenu",
      "ctrl-g p": "agent::ToggleProfileSelector",
    },
  },
  {
    "context": "",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-/": "workspace::ToggleBottomDock",
      "ctrl-shift-b": "multi_workspace::ToggleWorkspaceSidebar",
    },
  },
]

